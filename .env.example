# Restrict CORS to your own domain (leave empty for same-origin only)
# Example: https://sidelinien-mobil.vercel.app
ALLOWED_ORIGIN=

# Iron session password (at least 32 characters long)
SECRET_COOKIE_PASSWORD=your_complex_password_at_least_32_characters_long

# Shared password to access the site
SHARED_SITE_PASSWORD=your_shared_password

# Bluesky credentials
BLUESKY_IDENTIFIER=*.bsky.social
BLUESKY_PASSWORD=